use write_packet_counter_marker from packet_counter.console
use validation_fixture_packet_stream from packet_counter.fixture_source
use validate_counter_packet, PacketKind from packet_counter.packet
use Unit from wrela_std.core.unit
use NetworkPaths from wrela_std.target.uefi.firmware

fn write_packet_source_marker(source: Ptr) -> Unit:
    match validate_counter_packet(source=source, max_frame_bytes=64):
        case Ok(packet):
            if packet.kind == PacketKind.count:
                write_packet_counter_marker(count=packet.counter_delta + packet.payload_first)
                return {}

            write_packet_counter_marker(count=0)
            return {}

        case Err(error):
            write_packet_counter_marker(count=0)
            return {}

class PacketCounter:
    paths: NetworkPaths

    fn tick(self) -> Unit:
        for source in validation_fixture_packet_stream():
            write_packet_source_marker(source=source)

        return {}

    fn wait(self) -> Unit:
        return {}

fn new_packet_counter(paths: NetworkPaths) -> PacketCounter:
    return { paths: paths }
