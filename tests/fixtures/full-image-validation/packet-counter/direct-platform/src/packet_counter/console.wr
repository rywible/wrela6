use Unit from wrela_abi.core.unit
use UefiStatus from wrela_abi.target.uefi.status

platform fn output_string(message: Utf16Static) -> UefiStatus

fn write_packet_counter_marker(count: u8) -> Unit:
    if count == 0:
        output_string(utf16_static("WRELA_PACKET_COUNTER_DROPPED\r\n"))
        return {}

    output_string(utf16_static("WRELA_PACKET_COUNTER_OK\r\n"))
    return {}
