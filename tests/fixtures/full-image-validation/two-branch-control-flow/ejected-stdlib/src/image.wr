use write_console_string from wrela_std.target.uefi.console
use UefiStatus from wrela_std.target.uefi.status

uefi image TwoBranchControlFlowImage:
    fn boot() -> UefiStatus:
        if false:
            return UefiStatus.success

        if true:
            return write_console_string(utf16_static("WRELA_TWO_BRANCH_OK\r\n"))
        else:
            return UefiStatus.success
